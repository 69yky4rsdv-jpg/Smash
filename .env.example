# Base URL (for logout redirect, etc.)
# NEXT_PUBLIC_BASE_URL=https://smashpov.com

# Bunny.net API for SmashPov (smashpov.com) – admin import uses these when form is left blank
# Stream: Dashboard → Stream → your library → API
# BUNNY_STREAM_ACCESS_KEY=your-stream-api-key
# BUNNY_LIBRARY_ID=12345
# BUNNY_VIDEO_PULL_ZONE=vz-xxxxxxxx
# BUNNY_THUMBNAIL_PULL_ZONE=optional-thumb-pull-zone

# Resend – signup confirmation email when user enters email on /start
# Get API key at https://resend.com/api-keys; verify domain at https://resend.com/domains
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=noreply@yourdomain.com
